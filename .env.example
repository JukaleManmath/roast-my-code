# Django
SECRET_KEY=your-secret-key-here
DEBUG=True
DJANGO_SETTINGS_MODULE=config.settings.local
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DATABASE_URL=postgresql://postgres:postgres@db:5432/roastmycode

# Redis (channel layer + cache + celery broker + celery results)
REDIS_URL=redis://redis:6379/0
REDIS_CELERY_BROKER=redis://redis:6379/1
REDIS_CELERY_BACKEND=redis://redis:6379/2
REDIS_CACHE_URL=redis://redis:6379/3

# Gemini
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-1.5-flash

# GitHub (optional — without it, 60 req/hr rate limit applies)
GITHUB_TOKEN=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# Rate limits
ANONYMOUS_DAILY_LIMIT=5
AUTHENTICATED_DAILY_LIMIT=20

# Code size limits (lines)
ANONYMOUS_MAX_LINES=200
AUTHENTICATED_MAX_LINES=500

# File upload
MAX_UPLOAD_SIZE_BYTES=102400
