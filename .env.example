# Django
SECRET_KEY=your-secret-key-here
DEBUG=True
DJANGO_SETTINGS_MODULE=config.settings.local
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DATABASE_URL=postgresql://postgres:postgres@db:5432/panelreview

# Redis (channel layer + cache + celery broker + celery results)
REDIS_URL=redis://redis:6379/0
REDIS_CELERY_BROKER=redis://redis:6379/1
REDIS_CELERY_BACKEND=redis://redis:6379/2
REDIS_CACHE_URL=redis://redis:6379/3

# LLM — primary provider
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_DAILY_TOKEN_SOFT_LIMIT=85000

# LLM — fallback providers (Phase 4)
CEREBRAS_API_KEY=
GEMINI_FLASH_API_KEY=

# Prompt versioning (Phase 3)
PROMPT_VERSION=v1

# GitHub (optional — without it, 60 req/hr rate limit applies)
GITHUB_TOKEN=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
NEXT_PUBLIC_REDIRECT_URI=http://localhost:3000/auth/callback

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Rate limits
ANONYMOUS_DAILY_LIMIT=5
AUTHENTICATED_DAILY_LIMIT=20

# Code size limits (lines)
ANONYMOUS_MAX_LINES=200
AUTHENTICATED_MAX_LINES=500

# File upload
MAX_UPLOAD_SIZE_BYTES=102400
